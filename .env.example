# ================================
# TUDUMM PLATFORM — ENV TEMPLATE
# Copy to .env and fill in values
# ================================

# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# Auth
JWT_SECRET=change-me-in-production-min-32-chars
JWT_REFRESH_SECRET=another-secret-min-32-chars
NEXTAUTH_SECRET=nextauth-secret
NEXTAUTH_URL=http://localhost:3000

# OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Database
DATABASE_URL=postgresql://tudumm:tudumm@localhost:5432/tudumm
REDIS_URL=redis://localhost:6379
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DATABASE=tudumm

# Object Storage (MinIO or S3)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=tudumm
S3_REGION=us-east-1

# Kafka
KAFKA_BROKERS=localhost:9092

# RabbitMQ
RABBITMQ_URL=amqp://tudumm:tudumm@localhost:5672

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CONNECT_CLIENT_ID=ca_...

# Anthropic (AI enrichment)
ANTHROPIC_API_KEY=sk-ant-...

# CAPTCHA
CAPSOLVER_API_KEY=
TWOCAPTCHA_API_KEY=

# Proxy upstream (wholesale residential)
PROXY_UPSTREAM_URL=
PROXY_UPSTREAM_USER=
PROXY_UPSTREAM_PASS=

# Browser service
BROWSER_WS_ENDPOINT=ws://localhost:9222
MAX_BROWSER_INSTANCES=20

# Temporal (workflow orchestration)
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=tudumm

# Email (transactional)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@tudumm.io

# Monitoring
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
SENTRY_DSN=
